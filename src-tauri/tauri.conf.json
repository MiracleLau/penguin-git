{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Penguin Git",
  "version": "0.3.3",
  "identifier": "cc.4it.penguin-git",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Penguin Git",
        "width": 800,
        "height": 600,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJDQzlBRkRCM0M3NkU2QwpSV1JzYnNlei9ack1DeDVlWlVWOWtCWW13d055V2I4Q1FIeEFPV2diVmtDeDViZHhsU2RhcE1HeQo=",
      "endpoints": [
        "https://github.com/MiracleLau/penguin-git/releases/latest/download/latest.json"
      ]
    }
  }
}
